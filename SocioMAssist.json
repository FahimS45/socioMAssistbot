              "schema": "{\n  \"type\": \"object\",\n  \"properties\": {\n    \"relevant\": {\n      \"type\": \"boolean\",\n      \"description\": \"Whether the user message is a valid social media post generation or scheduling request\"\n    }\n  },\n  \"additionalProperties\": false,\n  \"required\": [\"relevant\"]\n}",
              "strict": true
            }
          }
        }
