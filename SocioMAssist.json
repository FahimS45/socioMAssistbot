      "parameters": {
        "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\"/>\n  <link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@800;900&display=swap\" rel=\"stylesheet\"/>\n  <style>\n    * { margin: 0; padding: 0; box-sizing: border-box; }\n    \n    html, body {\n      width: 1080px;\n      height: 1080px;\n      overflow: hidden;\n      font-family: 'Inter', sans-serif;\n      background: #0a0a0a;\n    }\n\n    .card-wrapper {\n      position: absolute;\n      inset: 0;\n      width: 1080px;\n      height: 1080px;\n      overflow: hidden;\n    }\n\n    .bg-gradient {\n      position: absolute;\n      inset: 0;\n      background:\n        radial-gradient(ellipse 80% 60% at 70% 0%, rgba(160, 71, 58, 0.45) 0%, transparent 60%),\n        radial-gradient(ellipse 60% 80% at 100% 100%, rgba(120, 40, 30, 0.3) 0%, transparent 55%),\n        radial-gradient(ellipse 100% 50% at 0% 50%, rgba(40, 20, 15, 0.6) 0%, transparent 70%),\n        linear-gradient(160deg, #1a0e0b 0%, #0a0a0a 40%, #0f0808 100%);\n      z-index: 1;\n    }\n\n    .geo-ring {\n      position: absolute;\n      width: 840px;\n      height: 840px;\n      border-radius: 50%;\n      border: 1px solid rgba(160, 71, 58, 0.12);\n      top: -280px;\n      right: -200px;\n      z-index: 2;\n    }\n\n    .geo-ring-2 {\n      position: absolute;\n      width: 560px;\n      height: 560px;\n      border-radius: 50%;\n      border: 1px solid rgba(160, 71, 58, 0.07);\n      top: -160px;\n      right: -80px;\n      z-index: 2;\n    }\n\n    .slash {\n      position: absolute;\n      top: 0;\n      right: 180px;\n      width: 1px;\n      height: 1080px;\n      background: linear-gradient(\n        to bottom,\n        transparent 0%,\n        rgba(160, 71, 58, 0.35) 25%,\n        rgba(160, 71, 58, 0.15) 60%,\n        transparent 100%\n      );\n      transform: rotate(15deg);\n      transform-origin: top center;\n      z-index: 3;\n    }\n\n    .bottom-glow {\n      position: absolute;\n      bottom: 0;\n      left: 0;\n      right: 0;\n      height: 480px;\n      background: linear-gradient(\n        to top,\n        rgba(160, 71, 58, 0.18) 0%,\n        rgba(160, 71, 58, 0.06) 50%,\n        transparent 100%\n      );\n      z-index: 4;\n    }\n\n    .bottom-rule {\n      position: absolute;\n      bottom: 0;\n      left: 0;\n      right: 0;\n      height: 6px;\n      background: linear-gradient(\n        90deg,\n        #A0473A 0%,\n        #C4584A 40%,\n        #A0473A 70%,\n        transparent 100%\n      );\n      z-index: 10;\n    }\n\n    .logo-wrap {\n      position: absolute;\n      top: 56px;\n      right: 56px;\n      z-index: 20;\n      width: 160px;\n      height: 160px;\n    }\n\n    .logo-img {\n      width: 100%;\n      height: 100%;\n      object-fit: contain;\n      filter: invert(1) brightness(1.1);\n    }\n\n    .title-block {\n      position: absolute;\n      bottom: 104px;\n      left: 88px;\n      right: 88px;\n      z-index: 20;\n    }\n\n    .title-accent {\n      width: 56px;\n      height: 6px;\n      background: #A0473A;\n      margin-bottom: 32px;\n      border-radius: 2px;\n    }\n\n    .card-title {\n      font-size: 84px;\n      font-weight: 900;\n      line-height: 1.05;\n      letter-spacing: -0.03em;\n      word-break: break-word;\n      background: linear-gradient(135deg, #ffffff 0%, #f0e8e6 60%, #d4a09a 100%);\n      -webkit-background-clip: text;\n      -webkit-text-fill-color: transparent;\n      background-clip: text;\n    }\n  </style>\n</head>\n<body>\n\n  <div class=\"card-wrapper\">\n    <div class=\"bg-gradient\"></div>\n    <div class=\"geo-ring\"></div>\n    <div class=\"geo-ring-2\"></div>\n    <div class=\"slash\"></div>\n    <div class=\"bottom-glow\"></div>\n    <div class=\"bottom-rule\"></div>\n\n    <div class=\"logo-wrap\">\n      <img class=\"logo-img\"\n           src=\"https://raw.githubusercontent.com/FahimS45/socioMAssistbot/main/assets/dope-01.png\"\n           alt=\"Brand logo\"/>\n    </div>\n\n    <div class=\"title-block\">\n      <div class=\"title-accent\"></div>\n      <h1 class=\"card-title\" id=\"card-title\">{{$json.title}}</h1>\n    </div>\n  </div>\n\n  <script>\n    const el = document.getElementById('card-title');\n    const len = el.textContent.trim().length;\n    if (len > 50)      el.style.fontSize = '56px';\n    else if (len > 36) el.style.fontSize = '68px';\n    else if (len > 24) el.style.fontSize = '76px';\n  </script>\n\n</body>\n</html>"
