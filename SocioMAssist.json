    {
      "parameters": {
        "chatId": "={{ $('telegramTrigger').item.json.message.chat.id }}",
        "text": "=Sorry, I can only help with social media posts! \n\nI can generate and schedule engaging posts for Facebook and Instagram. \n\n _Just tell me the topic and when you'd like it posted, for example:_  \"Write a post about AI trends and schedule it for tomorrow at 8PM\"",
